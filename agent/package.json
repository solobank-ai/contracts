{
  "name": "@solobank/ai-agent",
  "version": "0.1.0",
  "description": "AI Oracle agent for Solobank — calls OpenAI, signs decisions, submits to AI Vault",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "once": "tsx src/index.ts --once",
    "init-vault": "tsx scripts/init-vault.ts",
    "demo:allocate": "tsx scripts/demo-tick.ts allocate",
    "demo:rebalance": "tsx scripts/demo-tick.ts rebalance",
    "demo:risk-off": "tsx scripts/demo-tick.ts risk-off"
  },
  "dependencies": {
    "@solana/kit": "^6.5.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.13.0",
    "dotenv": "^16.4.5",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
